generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  mobile        String    @unique
  password      String
  role          Role

  shopName      String?
  city          String?
  state         String?
  pincode       String?

  aadharNo      String?
  panNo         String?

  bankName      String?
  accountNo     String?
  ifscCode      String?

  // Hierarchical Self-Relation
  parentId      String?
  parent        User?     @relation("UserHierarchy", fields: [parentId], references: [id])
  downlines     User[]    @relation("UserHierarchy")

  walletBalance  Float     @default(0.0)
  eWalletBalance Float     @default(0.0)  // AEPS e-wallet

  kycStatus     KYCStatus @default(PENDING)
  kycRequests   KYCRequest[]

  fundRequests  FundRequest[]

  transactions  Transaction[]

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Staff Permissions (JSON object, applicable for ADMIN/EMPLOYEE roles)
  permissions   Json?

  // Per-user Service Access (JSON object: { aeps: true, bbps: false, ... })
  serviceAccess Json?

  // PG Charge Overrides for this user
  pgChargeOverrides UserPGChargeOverride[]

  // OTP for Login Verification
  otp           String?
  otpExpiry     DateTime?
}

model Transaction {
  id            String    @id @default(uuid())
  amount        Float
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  service       String?   // AEPS, DMT, etc.
  description   String?

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model KYCRequest {
  id            String    @id @default(uuid())
  aadharFront   String?   // URL or path
  aadharBack    String?
  panImage      String?
  bankDoc       String?
  status        KYCStatus @default(PENDING)
  remark        String?

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CommissionPlan {
  id            String    @id @default(uuid())
  name          String
  role          Role
  service       String
  minAmount     Float
  maxAmount     Float
  commission    Float
  isPercentage  Boolean   @default(false)
  isActive      Boolean   @default(true)
}

enum Role {
  ADMIN
  EMPLOYEE
  SUPER_DISTRIBUTOR
  MASTER_DISTRIBUTOR
  DISTRIBUTOR
  RETAILER
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model FundRequest {
  id             String            @id @default(uuid())
  amount         Float
  mode           String            // Bank Transfer, UPI, Cash, etc.
  utr            String            @unique
  companyAccount String?
  proofImage     String?           // URL/Path to screenshot
  remark         String?
  status         FundRequestStatus @default(PENDING)
  
  userId         String
  user           User              @relation(fields: [userId], references: [id])

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum FundRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// -----------------------------------------------------------------------------
// NEW COMMISSION MODELS
// -----------------------------------------------------------------------------

model PGCharge {
  id         String   @id @default(uuid())
  method     String   // Card, Netbanking, Upi
  network    String   // VISA, MASTERCARD, RUPAY, -
  cardType   String   // credit, debit, -
  subType    String   // consumer, business, -
  rate       Float    // e.g. 1.50
  commission Float    // e.g. 0.00
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ServiceFee {
  id          String   @id @default(uuid())
  serviceKey  String   @unique // e.g. BNK_ACC_VRFY
  serviceName String
  feeAmount   Float
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PayoutChargeSlab {
  id            String   @id @default(uuid())
  minAmount     Float
  maxAmount     Float
  serviceCharge Float
  serviceName   String   @default("Payout")
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UserPGChargeOverride {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  method         String   // Card, Netbanking, Upi
  network        String   // VISA, MASTERCARD, RUPAY, -
  cardType       String   // credit, debit, -
  subType        String   // consumer, business, -
  rate           Float    // e.g. 1.50
  commission     Float    // e.g. 0.00
  
  // A user can only have one override per specific payment method/network combination
  @@unique([userId, method, network, cardType, subType])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminBankDetail {
  id            String   @id @default(uuid())
  bankName      String
  ifsc          String
  accountNumber String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
